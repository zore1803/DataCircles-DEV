# Copy this file to .env and fill in real values. Never commit .env.
# Ask a project owner for actual credentials — do not invent placeholder secrets that look real.

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- Database ---
MONGO_URI=

# --- Auth ---
JWT_SECRET=
JWT_EXPIRES_IN=7d
SUPER_ADMIN_JWT_SECRET=

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=

# --- Razorpay (Billing — see CODEOWNERS, do not modify without discussion) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Auth0 ---
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_NAMESPACE=

# --- AWS / S3 / CloudFront ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
CLOUDFRONT_DOMAIN=

# --- Redis ---
REDIS_URL=

# --- SMS / Email ---
FAST2SMS_KEY=
SENDGRID_API_KEY=
EMAIL_USER=
EMAIL_PASS=
MAIL_USER=
MAIL_PASS=

# --- Decentro ---
DECENTRO_CLIENT_ID=
DECENTRO_CLIENT_SECRET=
DECENTRO_MODULE_SECRET=

# --- Google service account ---
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- Zoom ---
ZOOM_API_KEY=
ZOOM_API_SECRET=
